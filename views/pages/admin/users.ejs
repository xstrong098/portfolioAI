<%- include('../../partials/layout', { body: `
<main class="admin-page py-5">
  <div class="container">
    <div class="admin-header mb-5">
      <span class="admin-badge"><i class="bi bi-shield-fill me-1"></i>Admin Panel</span>
      <h1 class="admin-title mt-2">Gestione Utenti</h1>
      <div class="admin-nav mt-3 d-flex gap-2 flex-wrap">
        <a href="/admin" class="btn btn-sm btn-outline-light">Dashboard</a>
        <a href="/admin/users" class="btn btn-sm btn-accent">Utenti</a>
        <a href="/admin/works" class="btn btn-sm btn-outline-light">Opere</a>
        <a href="/admin/tags" class="btn btn-sm btn-outline-light">Tag</a>
        <a href="/gallery" class="btn btn-sm btn-outline-secondary">← Sito</a>
      </div>
    </div>
    <div class="admin-card">
      <div class="admin-table-wrap">
        <table class="table table-dark table-hover admin-table">
          <thead>
            <tr><th>ID</th><th>Nome</th><th>Email</th><th>Opere</th><th>Ruolo</th><th>Stato</th><th>Azioni</th></tr>
          </thead>
          <tbody>
            ${users.map(u => `
            <tr>
              <td class="text-muted">#${u.id}</td>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="author-avatar-sm">${(u.full_name || u.username)[0].toUpperCase()}</div>
                  <div>
                    <strong>${u.username}</strong>
                    <div class="text-muted small">${u.full_name || ''}</div>
                  </div>
                </div>
              </td>
              <td class="text-muted small">${u.email}</td>
              <td><span class="badge bg-secondary">${u.work_count}</span></td>
              <td>
                <form action="/admin/users/${u.id}/role" method="POST" class="d-inline">
                  <select name="role" class="form-select form-select-sm admin-select" onchange="this.form.submit()">
                    <option value="user" ${u.role === 'user' ? 'selected' : ''}>User</option>
                    <option value="admin" ${u.role === 'admin' ? 'selected' : ''}>Admin</option>
                  </select>
                </form>
              </td>
              <td>
                <span class="badge ${u.is_active ? 'bg-success' : 'bg-danger'}">${u.is_active ? 'Attivo' : 'Disabilitato'}</span>
              </td>
              <td>
                <div class="d-flex gap-1">
                  <a href="/profile/${u.username}" class="btn btn-xs btn-outline-light" target="_blank"><i class="bi bi-person"></i></a>
                  ${u.role !== 'admin' ? `
                  <form action="/admin/users/${u.id}/toggle" method="POST">
                    <button class="btn btn-xs ${u.is_active ? 'btn-outline-danger' : 'btn-outline-success'}">
                      <i class="bi bi-${u.is_active ? 'slash-circle' : 'check-circle'}"></i>
                    </button>
                  </form>
                  ` : '<span class="text-muted small">—</span>'}
                </div>
              </td>
            </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>
` }) %>
