<nav class="navbar navbar-expand-lg navbar-dark sticky-top" id="mainNav">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/gallery">
      <span class="brand-icon"><i class="bi bi-layers-half"></i></span>
      Portfolio<span class="brand-accent">AI</span>
    </a>
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav mx-auto">
        <li class="nav-item">
          <a class="nav-link" href="/gallery"><i class="bi bi-grid-3x3-gap me-1"></i>Gallery</a>
        </li>
        <% if (user) { %>
        <li class="nav-item">
          <a class="nav-link" href="/portfolio/upload"><i class="bi bi-cloud-upload me-1"></i>Carica</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/profile/<%= user.username %>"><i class="bi bi-person-circle me-1"></i>Il mio Portfolio</a>
        </li>
        <% } %>
      </ul>
      <div class="navbar-actions d-flex align-items-center gap-2">
        <% if (user) { %>
          <% if (user.role === 'admin') { %>
            <a href="/admin" class="btn btn-sm btn-warning fw-semibold">
              <i class="bi bi-shield-fill me-1"></i>Admin
            </a>
          <% } %>
          <div class="dropdown">
            <button class="btn btn-sm btn-outline-light dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown">
              <% if (user.avatar) { %>
                <img src="<%= user.avatar %>" class="rounded-circle" width="24" height="24" style="object-fit:cover">
              <% } else { %>
                <div class="user-avatar-mini"><%= user.username[0].toUpperCase() %></div>
              <% } %>
              <span class="d-none d-md-inline"><%= user.username %></span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end dropdown-dark-custom">
              <li><a class="dropdown-item" href="/profile/<%= user.username %>"><i class="bi bi-person me-2"></i>Profilo</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
            </ul>
          </div>
        <% } else { %>
          <a href="/login" class="btn btn-sm btn-outline-light">Login</a>
          <a href="/register" class="btn btn-sm btn-accent">Registrati</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
