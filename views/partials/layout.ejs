<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — PortfolioAI</title>
  <!-- bootstrap 5 per i componenti e la griglia responsive -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- libreria di icone di bootstrap, ce ne sono un sacco -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <!-- i font da google fonts, syne per i titoli e dm sans per il testo -->
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <!-- il mio css personalizzato, lo carico per ultimo così sovrascrive bootstrap -->
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>

<%- include('./navbar') %>

<div class="flash-container">
  <% if (success && success.length > 0) { %>
    <% success.forEach(msg => { %>
      <div class="alert alert-success alert-dismissible fade show flash-alert" role="alert">
        <i class="bi bi-check-circle me-2"></i><%= msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% }) %>
  <% } %>
  <% if (error && error.length > 0) { %>
    <% error.forEach(msg => { %>
      <div class="alert alert-danger alert-dismissible fade show flash-alert" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i><%= msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% }) %>
  <% } %>
</div>

<%- body %>

<%- include('./footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
