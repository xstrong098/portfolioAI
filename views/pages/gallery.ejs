<%- include('../partials/layout', { body: `
<main class="gallery-page">

  <!-- sezione hero con il titolo grande e il sottotitolo -->
  <section class="gallery-hero">
    <div class="container">
      <div class="hero-content text-center">
        <div class="hero-badge mb-3"><i class="bi bi-stars me-1"></i>AI-Powered Portfolio Platform</div>
        <h1 class="hero-title">Dove il design<br><span class="gradient-text">incontra l'intelligenza</span></h1>
        <p class="hero-subtitle">Scopri opere grafiche straordinarie, analizzate e arricchite dall'AI</p>
        ${user ? '<a href="/portfolio/upload" class="btn btn-accent btn-lg mt-2"><i class="bi bi-plus-circle me-2"></i>Carica la tua opera</a>' : '<a href="/register" class="btn btn-accent btn-lg mt-2"><i class="bi bi-rocket me-2"></i>Inizia ora — È gratis</a>'}
      </div>
    </div>
    <div class="hero-grid-bg"></div>
  </section>

  <!-- barra di ricerca e filtro per tag e stile -->
  <section class="filter-bar sticky-filter">
    <div class="container">
      <div class="d-flex align-items-center gap-3 flex-wrap py-3">
        <div class="search-wrap flex-grow-1">
          <i class="bi bi-search search-icon"></i>
          <input type="text" id="searchInput" class="form-control search-input" placeholder="Cerca per titolo, stile, AI tag...">
        </div>
        <div class="filter-tags d-flex gap-2 flex-wrap">
          <button class="btn btn-sm tag-filter active" data-tag="">Tutti</button>
          ${tags.map(tag => `<button class="btn btn-sm tag-filter" data-tag="${tag.slug}" style="--tag-color:${tag.color}">${tag.name}</button>`).join('')}
        </div>
        <select id="styleFilter" class="form-select form-select-sm" style="width:auto">
          <option value="">Tutti gli stili</option>
          <option>Minimalist</option>
          <option>Brutalist</option>
          <option>Art Deco</option>
          <option>Swiss Style</option>
          <option>Maximalist</option>
          <option>Editorial</option>
          <option>Retro</option>
          <option>Organic</option>
        </select>
      </div>
    </div>
  </section>

  <!-- griglia masonry con tutte le opere pubbliche -->
  <section class="works-section py-5">
    <div class="container">
      <div id="worksGrid" class="works-masonry">
        ${works.length === 0 ? `
          <div class="col-12 text-center py-5">
            <i class="bi bi-images display-1 text-muted opacity-25"></i>
            <p class="mt-3 text-muted">Nessuna opera ancora. Sii il primo a condividere!</p>
            ${user ? '<a href="/portfolio/upload" class="btn btn-accent mt-2">Carica ora</a>' : '<a href="/register" class="btn btn-accent mt-2">Registrati e carica</a>'}
          </div>
        ` : works.map(work => {
          const tagNames = work.tag_names ? work.tag_names.split(',') : [];
          const tagColors = work.tag_colors ? work.tag_colors.split(',') : [];
          return `
          <div class="work-card" data-work-id="${work.id}" data-tags="${work.tag_names || ''}" data-style="${work.style_category || ''}">
            <a href="/portfolio/${work.id}" class="work-card-link">
              <div class="work-img-wrap">
                <img src="${work.image_path}" alt="${work.title}" class="work-img" loading="lazy">
                <div class="work-overlay">
                  <div class="work-overlay-content">
                    ${work.ai_description ? `<p class="work-ai-preview"><i class="bi bi-stars me-1"></i>${work.ai_description.substring(0,80)}...</p>` : '<p class="work-ai-preview text-muted"><i class="bi bi-cpu me-1"></i>Non ancora analizzato dall\'AI</p>'}
                    <div class="work-stats">
                      <span><i class="bi bi-eye"></i> ${work.views || 0}</span>
                      <span><i class="bi bi-heart"></i> ${work.likes || 0}</span>
                    </div>
                  </div>
                </div>
                ${work.is_featured ? '<div class="featured-badge"><i class="bi bi-star-fill"></i></div>' : ''}
              </div>
              <div class="work-meta">
                <h3 class="work-title">${work.title}</h3>
                <div class="work-author">
                  <div class="author-avatar-sm">${(work.full_name || work.username)[0].toUpperCase()}</div>
                  <span>${work.full_name || work.username}</span>
                  ${work.style_category ? `<span class="style-chip">${work.style_category}</span>` : ''}
                </div>
                <div class="work-tags-row mt-2">
                  ${tagNames.slice(0,3).map((t, i) => `<span class="tag-chip" style="background:${tagColors[i] || '#6c757d'}22;color:${tagColors[i] || '#6c757d'};border-color:${tagColors[i] || '#6c757d'}44">${t}</span>`).join('')}
                </div>
              </div>
            </a>
          </div>
        `}).join('')}
      </div>
    </div>
  </section>

</main>
` }) %>
